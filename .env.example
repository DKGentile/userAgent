# =============================================================================
# Aegis — Autonomous Claims Intelligence : environment configuration
# =============================================================================
# EVERYTHING here is OPTIONAL. With no .env at all, the app runs fully offline
# with a deterministic agent simulator and dependency-free feature-hashing
# embeddings. Add keys below to light up real Claude + production embeddings.
#
# Copy to ".env" (cp .env.example .env) and fill in what you have.
# -----------------------------------------------------------------------------

# --- LLM (optional) ----------------------------------------------------------
# When present, the decision agent calls the real Claude API (tool use +
# extended thinking + streaming). When absent, a built-in deterministic
# reasoner produces a realistic decision so the demo always works.
ANTHROPIC_API_KEY=

# Model selection (defaults shown). Override to taste.
AGENT_MODEL=claude-sonnet-4-6
ANALYZER_MODEL=claude-haiku-4-5-20251001
AGENT_THINKING_BUDGET=1600

# --- Embeddings (optional) ---------------------------------------------------
# Embedding provider is chosen automatically:
#   1. OPENAI_API_KEY  -> text-embedding-3-small  (1536-dim)
#   2. VOYAGE_API_KEY  -> voyage-3                 (1024-dim, Anthropic partner)
#   3. (neither)       -> built-in feature-hashing provider (384-dim, offline)
OPENAI_API_KEY=
VOYAGE_API_KEY=

# --- Decision policy ---------------------------------------------------------
AGENT_MIN_CONFIDENCE=0.80

# --- Server ------------------------------------------------------------------
PORT=8787
# When NODE_ENV=production the server also serves the built React app.
NODE_ENV=development
